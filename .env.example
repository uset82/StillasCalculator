# Server-side only. Never expose to the client bundle (Req 12.6, 12.7).
# AI provider selection:
# - openrouter-api: public deployment mode; use the app owner's server-side
#   OpenRouter key so visitors can try the assistant without signing in
# - auto: use OPENROUTER_API_KEY when present; otherwise use local Codex auth
# - openai-account: legacy account mode; proxy each browser session to the
#   persistent Codex backend, where users sign in with ChatGPT device code auth
# - openai-api: legacy value; no longer used by the hosted assistant
# - codex-cli/openai-codex: require `codex login` / Codex Desktop ChatGPT auth,
#   then run the assistant through @openai/codex-sdk
# - off: disable the assistant
STILLAS_AI_PROVIDER=openrouter-api

# Required for STILLAS_AI_PROVIDER=openrouter-api. Store the real key only in
# your local environment or the Netlify UI/CLI. `openrouter/free` routes to
# available free models and is intended for low-volume demos.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=StillasCalculator

# Required only for STILLAS_AI_PROVIDER=openai-account.
# Run the backend with `npm run codex-backend`; store the secret only in your
# local environment or Netlify UI, never in source control.
STILLAS_CODEX_BACKEND_URL=http://localhost:8787
STILLAS_CODEX_BACKEND_SECRET=change-me
# Optional but recommended. If omitted, the backend secret signs auth cookies.
STILLAS_AI_AUTH_COOKIE_SECRET=change-me-too
STILLAS_CODEX_DATA_DIR=.stillas-codex-backend
STILLAS_CODEX_SESSION_TTL_SECONDS=86400

# Legacy OpenAI API-key path. The hosted assistant now uses OpenRouter instead.
OPENAI_API_KEY=

# Optional legacy model overrides.
OPENAI_MODEL=
STILLAS_CODEX_MODEL=gpt-5.5
